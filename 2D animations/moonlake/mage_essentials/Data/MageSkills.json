{
  "_meta": {
    "title": "Mage Essentials Skill Data",
    "version": "1.0",
    "ro_reference": "iRO/kRO classic Mage skills as of pre-Renewal era.",
    "scaling_rules": {
      "FIRE_BOLT":      "BoltCount = SkillLevel. CastTime = 1.5 + 0.2*(Level-1). 1 hit per bolt; each bolt rolls damage independently.",
      "COLD_BOLT":      "BoltCount = SkillLevel. CastTime = 1.5 + 0.2*(Level-1). Element Water; useful in elemental endow combos.",
      "LIGHTNING_BOLT": "BoltCount = SkillLevel. CastTime = 1.5 + 0.2*(Level-1). Element Wind.",
      "FIRE_WALL":      "Width = 3 cells; persists for ~5s OR HitsPerCell hits, whichever comes first. HitsPerCell increases with level."
    },
    "damage_formula": "BoltDamage = (MATK_min..MATK_max) * DamageMultiplier * ElementalModifier * (1 - TargetMDef%) - TargetMDef_flat. Re-rolled per bolt.",
    "element_modifiers": {
      "Fire->Earth":  1.5,  "Fire->Water":  0.5,  "Fire->Fire": 0.25, "Fire->Wind":   1.0,
      "Water->Fire": 1.5,   "Water->Earth": 1.0,  "Water->Water":0.25,"Water->Wind":  0.5,
      "Wind->Water": 1.5,   "Wind->Earth":  0.5,  "Wind->Fire":  1.0, "Wind->Wind":   0.25
    },
    "vfx_pipeline": {
      "cast_glow":  "Loop on caster's hand/staff for full CastTime. Stop on cast finish or interrupt.",
      "projectile": "Spawn at caster -> seek target. One projectile per BoltCount, fired at BoltInterval seconds apart.",
      "impact":     "One-shot at hit position. Plays for ~0.5s.",
      "fire_wall_burst":  "One-shot ignition at each cell on cast.",
      "fire_wall_pillar": "Loop at each cell for the wall's lifetime."
    }
  },
